# ═══════════════════════════════════════════════════════════════════
# ACTIVA INVERSIONES — whatsapp-ia-hubspot — Variables de Entorno
# Versión: 9.5.1-prod | Actualizado: 2026-03-27
# ═══════════════════════════════════════════════════════════════════

# ─── APP ───
PORT=8080
TZ=America/Santiago
NODE_ENV=production

# ─── WHATSAPP CLOUD API (Meta) ───
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=
VERIFY_TOKEN=
APP_SECRET=
META_GRAPH_VERSION=v22.0

# ─── OPENAI ───
OPENAI_API_KEY=sk-...
AI_MODEL_OPENAI=gpt-4o-mini
AI_MODEL_STT=whisper-1

# ─── COTIZADOR (único motor de precios) ───
PRICER_MODE=cotizador_winhouse
COTIZADOR_BASE_URL=https://cotizador-winhouse-production.up.railway.app
COTIZADOR_API_KEY=

# ─── ZOHO CRM + BOOKS ───
REQUIRE_ZOHO=true
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=
ZOHO_API_DOMAIN=https://www.zohoapis.com
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com
ZOHO_DEAL_PHONE_FIELD=WhatsApp_Phone
ZOHO_DEFAULT_ACCOUNT_NAME=Clientes WhatsApp IA
ZOHO_DEFAULT_ITEM_ID=
ZOHO_TAX_ID=

# ─── VOZ (ElevenLabs) ───
VOICE_ENABLED=true
VOICE_SEND_MODE=audio_if_inbound_audio
VOICE_TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# ─── ADMIN (control por WhatsApp) ───
ADMIN_PHONE=+56957296035
ADMIN_PIN=1976

# ─── ESCALACIÓN ───
ESCALATION_PHONE=+56957296035
ESCALATION_EMAIL=oliver@activainversiones.cl

# ─── SALES OS ───
SALES_OS_URL=https://activa-sales-os-production.up.railway.app
SALES_OS_INGEST_TOKEN=
SALES_OS_OPERATOR_TOKEN=

# ─── EMPRESA ───
COMPANY_NAME=Activa Inversiones
COMPANY_PHONE=+56 9 5729 6035
COMPANY_EMAIL=ventas@activainversiones.cl
COMPANY_ADDRESS=Temuco, La Araucanía, Chile
COMPANY_WEBSITE=www.activainversiones.cl
COMPANY_RUT=76.XXX.XXX-X
AGENT_NAME=Marcelo Cifuentes

# ─── QUOTE API (endpoint /quote) ───
QUOTE_API_KEY=

# ─── VIDRIO DEFAULT ───
DEFAULT_GLASS=DVH 4+12+4 CL

# ═══════════════════════════════════════════════════════════════════
# VARIABLES QUE NO DEBEN EXISTIR (eliminar si las tienes):
# PRICING_FILE          ← NO HAY precios estáticos
# WINPERFIL_API_BASE    ← Solo usamos cotizador-winhouse
# WINPERFIL_API_KEY     ← Solo usamos cotizador-winhouse
# COTIZADOR_WINHOUSE_URL ← Usar COTIZADOR_BASE_URL
# COTIZADOR_WINHOUSE_API_KEY ← Usar COTIZADOR_API_KEY
