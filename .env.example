# ═══════════════════════════════════════════════════════════════════════════════
# FERRARI 5.0 — Variables de Entorno para Railway
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────
# META / WHATSAPP (OBLIGATORIO)
# ─────────────────────────────────────────────────────────────────────────────────
WHATSAPP_TOKEN=tu_token_permanente_de_whatsapp
PHONE_NUMBER_ID=tu_phone_number_id
VERIFY_TOKEN=tu_verify_token_personalizado
APP_SECRET=tu_app_secret_opcional

# Versión de la API de Meta (opcional, default: v22.0)
META_GRAPH_VERSION=v22.0

# ─────────────────────────────────────────────────────────────────────────────────
# OPENAI (OBLIGATORIO)
# ─────────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-tu-api-key-de-openai

# Modelos (opcional, estos son los defaults)
AI_MODEL_OPENAI=gpt-4o-mini
AI_MODEL_CLASSIFIER=gpt-4o-mini
AI_MODEL_STT=whisper-1

# ─────────────────────────────────────────────────────────────────────────────────
# ZOHO CRM (OBLIGATORIO si REQUIRE_ZOHO=true)
# ─────────────────────────────────────────────────────────────────────────────────
REQUIRE_ZOHO=true

ZOHO_CLIENT_ID=tu_client_id_de_zoho
ZOHO_CLIENT_SECRET=tu_client_secret_de_zoho
ZOHO_REFRESH_TOKEN=tu_refresh_token_de_zoho
ZOHO_REDIRECT_URI=https://tu-app.railway.app/zoho/callback

# Dominios Zoho (ajustar según tu datacenter)
# Para Chile/Latinoamérica generalmente es .com
ZOHO_API_DOMAIN=https://www.zohoapis.com
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.com

# ─────────────────────────────────────────────────────────────────────────────────
# ZOHO - CAMPOS PERSONALIZADOS (OPCIONAL)
# ─────────────────────────────────────────────────────────────────────────────────
# Si creaste un campo "Perfil Cliente" en Leads, pon su API Name aquí
# Para encontrarlo: Setup → Developer Space → APIs → API Names → Módulo Leads
ZOHO_LEAD_PROFILE_FIELD=

# Si creaste un campo "Perfil Cliente" en Deals/Potentials, pon su API Name aquí
# Para encontrarlo: Setup → Developer Space → APIs → API Names → Módulo Potentials
ZOHO_DEAL_PROFILE_FIELD=

# Nombre de cuenta por defecto para Deals (usado si no tienes Account vinculado)
ZOHO_DEFAULT_ACCOUNT_NAME=Clientes WhatsApp IA

# ─────────────────────────────────────────────────────────────────────────────────
# COMPORTAMIENTO (OPCIONAL)
# ─────────────────────────────────────────────────────────────────────────────────
# Enviar PDF automáticamente cuando los datos estén completos
AUTO_SEND_PDF_WHEN_READY=true

# Zona horaria para fechas en PDF
TZ=America/Santiago

# Puerto (Railway lo asigna automáticamente, no cambiar)
PORT=8080
# ===== Human-like WhatsApp sending =====
HUMAN_ENABLED=true
HUMAN_MIN_DELAY_MS=650
HUMAN_MAX_DELAY_MS=2200
HUMAN_CHUNK_MAX_CHARS=900
HUMAN_EXTRA_DELAY_PER_100CH=220
HUMAN_MEDIA_ACK=true
# ===== Zoho Deals (recommended) =====
# Campo custom en Deals para guardar el teléfono (solo dígitos) y hacer dedupe:
# ZOHO_DEAL_PHONE_FIELD=WA_E164
# Si cambias los nombres exactos de las etapas en Zoho, sobrescribe aquí:
# ZOHO_STAGE_DIAGNOSTICO=Diagnóstico y Perfilado
# ZOHO_STAGE_SIEMBRA=Siembra de Confianza + Marco Normativo (OGUC/RT)
# ZOHO_STAGE_PROPUESTA=Presentación de Propuesta
# ZOHO_STAGE_OBJECIONES=Incubadora de Objeciones
# ZOHO_STAGE_VALIDACION=Validación Técnica y Normativa
# ZOHO_STAGE_CIERRE=Cierre y Negociación
# ZOHO_STAGE_GANADO=Cerrado ganado
# ZOHO_STAGE_PERDIDO=Cerrado perdido
# ZOHO_STAGE_COMPETENCIA=Perdido y cerrado para la competencia

# SALES OS BRIDGE / TAKEOVER (RECOMENDADO EN PRODUCCIÃ“N)
AGENT_NAME=Asesor ACTIVA
SALES_OS_URL=https://ops.activalabs.ai
SALES_OS_INGEST_TOKEN=
SALES_OS_OPERATOR_TOKEN=
OPERATOR_API_TOKEN=

# takeover humano y estilo
HUMAN_HANDOFF_ENABLED=true

# COTIZADOR WINHOUSE (RECOMENDADO EN PRODUCCIÓN)
# Variables canónicas para la integración con cotizador-winhouse
# Docs: https://github.com/activa-inversiones/cotizador-winhouse
PRICER_MODE=cotizador_winhouse
COTIZADOR_BASE_URL=https://cotizador-winhouse-production.up.railway.app
COTIZADOR_API_KEY=tu_api_key_del_cotizador
COTIZADOR_TIMEOUT_MS=15000
# Alternativa Railway (red privada interna, más rápida y sin costo de egress):
# COTIZADOR_BASE_URL=http://${{cotizador-winhouse.RAILWAY_PRIVATE_DOMAIN}}:${{cotizador-winhouse.PORT}}
# Variables legacy (aún aceptadas como fallback, se migrarán en v2):
# COTIZADOR_WINHOUSE_URL=...
# COTIZADOR_WINHOUSE_API_KEY=...

